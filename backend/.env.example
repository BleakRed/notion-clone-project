# Database connection string (e.g., PostgreSQL for Render)
DATABASE_URL="postgresql://user:password@localhost:5432/notion_clone?schema=public"

# Secret for JWT signing
JWT_SECRET="your_very_secure_random_secret_here"

# Port to run the server on (Render will provide this automatically)
PORT=8000

# Frontend URL for CORS and email links
FRONTEND_URL="http://localhost:3000"

# SMTP Configuration
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Notion Clone <your-email@gmail.com>"
SMTP_FROM_NAME="Notion Clone"

# Cloudinary Configuration (For persistent file storage on Render Free Tier)
# Sign up at https://cloudinary.com/ for a free account
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
